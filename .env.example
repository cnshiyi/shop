# Django
# Generate SECRET_KEY and CONFIG_ENCRYPTION_KEY as different strong random strings before deployment.
DEBUG=1
SECRET_KEY=change-me
CONFIG_ENCRYPTION_KEY=change-me
ALLOWED_HOSTS=127.0.0.1,localhost

# Dashboard bootstrap admin
DASHBOARD_ADMIN_USERNAME=admin
DASHBOARD_ADMIN_PASSWORD=change-me
DASHBOARD_ADMIN_EMAIL=

# Database
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=shop
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=shop

# Redis
REDIS_URL=redis://127.0.0.1:6379/0
FSM_STATE_TTL=1800
FSM_DATA_TTL=1800

# Telegram / TRON
BOT_TOKEN=
TRONGRID_API_KEY=
RECEIVE_ADDRESS=
SCANNER_VERBOSE=0

# Cloud providers
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
DEFAULT_SERVER_IMAGE=debian
